---
import BaseHead from '../components/BaseHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SearchOverlay from '../components/SearchOverlay.astro';

interface Props {
  title?: string;
  description?: string;
  active?: string; // 활성 내비 메뉴
}
const { title, description, active = '홈' } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Navbar active={active} />
    <slot />
    <Footer />
    <SearchOverlay />
    <div class="backdrop" id="backdrop"></div>

    <script>
      // 모바일 사이드바 드로어 (.sidebar-toggle[data-target] → 해당 사이드바 열기)
      document.querySelectorAll('.sidebar-toggle').forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-target');
          document.getElementById(target)?.classList.add('is-open');
          document.getElementById('backdrop')?.classList.add('is-open');
        });
      });
      document.getElementById('backdrop')?.addEventListener('click', () => {
        document.querySelectorAll('.sidebar').forEach((s) => s.classList.remove('is-open'));
        document.getElementById('backdrop')?.classList.remove('is-open');
      });
    </script>
  </body>
</html>
