---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { PROFILE } from '../consts';
import { catColor, fmtDate, href } from '../utils';
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  posts: CollectionEntry<'blog'>[];
  headings: MarkdownHeading[];
}
const { post, posts, headings } = Astro.props;
const { title, description, category, tags, pubDate, readingTime } = post.data;
const color = catColor(category);
---

<BaseLayout title={title} description={description} active="블로그">
  <div class="shell is-post">
    <Sidebar posts={posts} active={category} showTags={false} id="sidebar" />

    <article class="article">
      <button class="sidebar-toggle" data-target="sidebar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h10M4 18h13"/></svg>
        카테고리
      </button>

      <div class="article__head">
        <span class="article__cat" style={`color:${color}`}>{category.toUpperCase()}</span>
        <h1>{title}</h1>
        <div class="article__meta">
          <span><span class="av">{PROFILE.initials}</span> {PROFILE.name}</span>
          <span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/></svg>
            {fmtDate(pubDate)}
          </span>
          {readingTime && (
            <span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              {readingTime}
            </span>
          )}
        </div>
        <div class="article__tags">
          {tags.map((t) => <a class="tag" href={href('blog/') + '?tag=' + encodeURIComponent(t)}>{t}</a>)}
        </div>
      </div>

      <div class="prose">
        <slot />
      </div>
    </article>

    <TableOfContents headings={headings} />
  </div>
</BaseLayout>
