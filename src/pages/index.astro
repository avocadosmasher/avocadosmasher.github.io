---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { PROFILE, SKILLS, CATEGORIES } from '../consts';
import { href } from '../utils';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recent = posts.slice(0, 3);
const catCount = Object.keys(CATEGORIES).length;

// bioLines 의 {강조} 마크업 처리
function renderBio(line: string) {
  return line.replace(/\{([^}]+)\}/g, '<em>$1</em>');
}
---

<BaseLayout active="홈">
  <div class="home">
    <section class="hero">
      <div>
        <p class="hero__eyebrow">{PROFILE.role} · {PROFILE.location}</p>
        <h1 set:html={PROFILE.bioLines.map(renderBio).join('<br>')}></h1>
        <p class="hero__bio">{PROFILE.intro}</p>
        <div class="hero__meta">
          <span><b>{PROFILE.career}</b> 경력</span>
          <span><b>{posts.length}</b> 편의 글</span>
          <span><b>{catCount}</b> 카테고리</span>
        </div>
        <div class="hero__actions">
          <a class="btn btn--primary" href={href('blog/')}>
            글 둘러보기
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="btn btn--ghost" href={PROFILE.socials.github}>GitHub</a>
        </div>
      </div>

      <div class="profile-card">
        <div class="avatar">{PROFILE.initials}</div>
        <h3>{PROFILE.name}</h3>
        <p class="role">{PROFILE.handle} · {PROFILE.role}</p>
        <div class="profile-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7l9 6 9-6"/><rect x="3" y="5" width="18" height="14" rx="2"/></svg>
          {PROFILE.email}
        </div>
        <div class="profile-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/></svg>
          {PROFILE.website}
        </div>
        <div class="profile-row">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12c0 4.4 2.9 8.2 6.8 9.5.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.9.8.1-.6.3-1.1.6-1.4-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.6 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.3.1 2.6.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.6 5 .4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5A10 10 0 0 0 22 12c0-5.5-4.5-10-10-10z"/></svg>
          {PROFILE.github}
        </div>
        <div class="socials">
          <a href={PROFILE.socials.github} aria-label="github"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12c0 4.4 2.9 8.2 6.8 9.5.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.9.8.1-.6.3-1.1.6-1.4-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.6 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.3.1 2.6.6.7 1 1.6 1 2.7 0 3.9-2.3 4.7-4.6 5 .4.3.7.9.7 1.9v2.8c0 .3.2.6.7.5A10 10 0 0 0 22 12c0-5.5-4.5-10-10-10z"/></svg></a>
          <a href={PROFILE.socials.x} aria-label="x"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-7.3 8.3L23 22h-6.6l-5.2-6.8L5.3 22H2.2l7.8-8.9L1.5 2h6.8l4.7 6.2L18.9 2zm-2.3 18h1.8L7.5 3.9H5.6L16.6 20z"/></svg></a>
          <a href={PROFILE.socials.linkedin} aria-label="linkedin"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.1c.5-1 1.8-2 3.7-2 4 0 4.7 2.6 4.7 6V21h-4v-5.3c0-1.3 0-2.9-1.8-2.9s-2 1.4-2 2.8V21H9z"/></svg></a>
        </div>
      </div>
    </section>

    <section class="home-section">
      <div class="section-head"><h2>요즘 쓰는 기술</h2></div>
      <div class="skill-strip">
        {SKILLS.map((s, i) => <span class="skill" set:html={i % 4 === 0 ? `<em>${s}</em>` : s}></span>)}
      </div>
    </section>

    <section class="home-section">
      <div class="section-head">
        <h2>최근 글</h2>
        <a class="more" href={href('blog/')}>전체 보기 →</a>
      </div>
      <div class="recent-grid">
        {recent.map((post) => <PostCard post={post} />)}
      </div>
    </section>
  </div>
</BaseLayout>
